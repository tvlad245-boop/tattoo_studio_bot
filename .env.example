# Telegram
BOT_TOKEN=

# Список админов через запятую (Telegram user id)
ADMIN_IDS=

# Путь к SQLite (создаётся автоматически)
DATABASE_PATH=./data/bot.db

# Часовой пояс студии (IANA), дублирует дефолт в БД до первого изменения в админке
STUDIO_TIMEZONE=Europe/Moscow

# Опционально: ЮKassa (если пусто — только оплата по реквизитам из настроек)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
